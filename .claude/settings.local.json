      "Bash(systemctl:*)",
      "Bash(reboot:*)",
      "Bash(poweroff:*)",
      "Bash(shutdown:*)",
      "Bash(halt:*)",
      "Bash(useradd:*)",
      "Bash(userdel:*)",
      "Bash(usermod:*)",
      "Bash(passwd:*)"
    ]
  }
